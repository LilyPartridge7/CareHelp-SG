# Backend Environment Variables
# Copy this file to .env and fill in the values

# Secret key for JWT signing (Required)
JWT_SECRET="YOUR_SECRET_KEY_HERE"

# Database Configuration 
# (Defaults are usually handled by docker-compose/Go code)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=carehelp_db

# Cloudinary Configuration (Optional for basic local testing)
# Required only if you want to test image uploads.
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=cloudinary://your_key:your_secret@your_name
